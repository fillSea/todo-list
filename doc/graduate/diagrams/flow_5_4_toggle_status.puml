@startuml 任务状态切换流程图
' 图5.4 任务状态切换流程图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml

skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  DiamondBackgroundColor #FFF8E1
  DiamondBorderColor #F57F17
}

skinparam defaultFontSize 14
skinparam activityFontSize 13
skinparam dpi 150

start

:用户点击任务复选框;
:前端发送状态切换请求;

partition "云函数处理" {
  :查询任务与当前用户信息;

  if (有修改权限?) then (是)
  else (否)
    :返回“无权限修改”;
    stop
  endif

  if (周期任务且目标为完成?) then (是)
    if (符合完成规则?) then (是)
    else (否)
      :返回确认或日期限制提示;
      stop
    endif
  else (否)
  endif

  if (目标为未完成且需确认?) then (是)
    :返回取消完成确认提示;
    stop
  else (否)
  endif

  :更新任务状态;
  :记录操作日志;
}

if (状态切换成功?) then (是)
  if (周期任务刚完成?) then (是)
    :生成后续周期实例\n并刷新任务列表;
  else (否)
    :更新本地状态\n并重新分组展示;
  endif
  :提示操作成功;
else (否)
  :提示失败原因;
endif

stop

@enduml
