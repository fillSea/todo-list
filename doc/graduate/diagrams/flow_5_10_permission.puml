@startuml 权限验证流程图
' 图5.10 权限验证流程图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml

skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  DiamondBackgroundColor #FFF8E1
  DiamondBorderColor #F57F17
}

skinparam defaultFontSize 14
skinparam activityFontSize 13
skinparam dpi 150

start

:接收清单操作请求;
:获取当前用户和目标清单;

partition "权限验证" {
  :查询用户的清单成员记录;

  if (找到成员记录?) then (是)
    :读取当前角色;
  else (否)
    if (是清单创建者?) then (是)
      :视为创建者角色;
    else (否)
      :返回“不是清单成员”;
      stop
    endif
  endif

  if (角色满足操作要求?) then (是)
    :返回允许操作;
  else (否)
    :返回“权限不足”;
    stop
  endif
}

:继续执行业务逻辑;

stop

@enduml
