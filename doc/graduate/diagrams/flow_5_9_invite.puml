@startuml 成员邀请流程图
' 图5.9 成员邀请流程图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml

skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  DiamondBackgroundColor #FFF8E1
  DiamondBorderColor #F57F17
}

skinparam defaultFontSize 14
skinparam activityFontSize 13
skinparam dpi 150

|创建者|
start

:进入清单详情页\n点击"邀请成员";
:选择邀请方式并设置参数;
:系统创建邀请记录;
:发送邀请给目标用户;

|被邀请人|

:收到并查看邀请信息;

if (选择接受?) then (接受)

  :系统校验邀请有效性\n和成员状态;

  if (校验通过?) then (是)
  else (否)
    :提示邀请无效或已过期;
    stop
  endif

  if (需要审批?) then (是)
    :提交加入申请\n并通知创建者审批;

    |创建者|
    :查看申请并作出审批;
    if (同意加入?) then (同意)
      :创建成员记录\n并更新邀请状态;
      |被邀请人|
      :收到通过通知并加入清单;
    else (拒绝)
      :更新邀请状态为拒绝;
      |被邀请人|
      :收到拒绝通知;
      stop
    endif

  else (否)
    :直接创建成员记录\n并更新邀请状态;
  endif

  :成功加入清单;

else (拒绝)
  :更新邀请状态为拒绝;
  stop
endif

stop

@enduml
