@startuml 通知消息加载流程图
' 图5.15 通知消息加载流程图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml

skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  DiamondBackgroundColor #FFF8E1
  DiamondBorderColor #F57F17
}

skinparam defaultFontSize 14
skinparam activityFontSize 13
skinparam dpi 150

start

:进入通知消息页面\n触发 onLoad;

:初始化页码与筛选条件;

:调用 loadNotifications();

partition "loadNotifications()" {
  :显示加载状态 loading=true;

  :请求当前页通知数据;

  if (返回成功?) then (是)
    :渲染通知列表;
    :更新分页状态;
  else (否)
    :显示加载失败提示;
  endif

  :隐藏加载状态 loading=false;
}

while (用户停留在页面?) is (是)

  switch (用户操作?)

  case (下拉刷新)
    :重置 page=1, hasMore=true;
    :调用 loadNotifications()\n重新加载第一页;

  case (上拉加载更多)
    if (hasMore 且 非加载中?) then (是)
      :页码加 1;
      :请求下一页通知数据;
      if (返回成功?) then (是)
        :追加到现有列表末尾;
        :更新 hasMore;
      else (否)
        :显示加载失败提示;
      endif
    else (否)
      :显示"没有更多了";
    endif

  case (切换通知类型)
    :更新 currentType;
    :重置 page=1, hasMore=true;
    :调用 loadNotifications()\n按新类型加载;

  endswitch

endwhile (离开页面)

stop

@enduml
