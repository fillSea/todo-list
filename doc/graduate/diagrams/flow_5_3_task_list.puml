@startuml 任务列表加载流程图
' 图5.3 任务列表加载流程图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml

skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  DiamondBackgroundColor #FFF8E1
  DiamondBorderColor #F57F17
}

skinparam defaultFontSize 14
skinparam activityFontSize 13
skinparam dpi 150

start

:页面触发 onShow 生命周期;

if (用户已登录?) then (是)
  :同时加载分类数据和任务数据;
else (否)
  :显示未登录提示;
  stop
endif

fork
  :读取本地分类缓存;
  if (缓存存在?) then (是)
    :立即显示分类数据;
  else (否)
  endif
  :请求最新分类数据;
  if (返回成功?) then (是)
    :更新界面与本地缓存;
  else (否)
    :保持缓存数据;
  endif

fork again
  :读取本地任务缓存;
  if (缓存存在?) then (是)
    :立即显示任务列表;
  else (否)
  endif
  :请求最新任务数据;
  if (返回成功?) then (是)
    :处理任务数据并更新缓存;
  else (否)
    :保持缓存数据;
  endif
end fork

partition "任务分组处理" {
  :计算任务显示状态;
  :按规则过滤周期任务;
  :按进行中、已逾期、已完成分组;

  fork
    :进行中任务;
  fork again
    :已逾期任务;
  fork again
    :已完成任务;
  end fork

  if (当前选中分类 ≠ 全部?) then (是)
    :按分类筛选展示结果;
  else (否)
  endif

  :更新页面渲染;
}

stop

@enduml
