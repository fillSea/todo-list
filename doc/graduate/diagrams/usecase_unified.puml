@startuml 系统用例图
' ============================================
' 图3.2 系统用例图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml
' ============================================

left to right direction
skinparam actorStyle hollow
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FAFAFA
  BorderColor #666666
  FontSize 11
}
skinparam actor {
  FontSize 12
}
skinparam rectangle {
  BorderColor #333333
  FontSize 13
  FontStyle bold
}

' ========== 参与者（左侧） ==========
actor "用户" as U
actor "清单\n创建者" as C
actor "清单\n编辑者" as E
actor "清单\n查看者" as V

C -u-|> U
E -u-|> U
V -u-|> U

' ========== 系统边界 ==========
rectangle "协同待办清单系统" {

  usecase "微信授权登录" as A1
  usecase "管理个人任务" as A2
  usecase "查看列表视图" as A3
  usecase "查看日历视图" as A4

  usecase "创建/管理清单" as B1
  usecase "邀请成员" as B2
  usecase "管理清单成员" as B3
  usecase "清单中管理任务" as B4
  usecase "查看清单任务" as B5
  usecase "查看操作记录" as B6
  usecase "接受/拒绝邀请" as B7

  usecase "修改个人信息" as C1
  usecase "查看数据统计" as C2
  usecase "查看通知消息" as C3
  usecase "管理分类标签" as C4
}

' ========== 用户关联 ==========
U --> A1
U --> A2
U --> A3
U --> A4
U --> B7
U --> C1
U --> C2
U --> C3
U --> C4

' ========== 创建者关联 ==========
C --> B1
C --> B2
C --> B3
C --> B4
C --> B5
C --> B6

' ========== 编辑者关联 ==========
E --> B4
E --> B5
E --> B6

' ========== 查看者关联 ==========
V --> B5
V --> B6

@enduml
