@startuml 清单成员实体E-R图
' ============================================
' 图4.7 清单成员实体属性图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml
' ============================================

skinparam defaultFontSize 13
skinparam defaultFontName Microsoft YaHei
skinparam backgroundColor white
skinparam shadowing false

skinparam rectangle {
  BorderColor #000000
  BackgroundColor #FFFFFF
  FontSize 14
  FontStyle bold
  BorderThickness 2
}

skinparam usecase {
  BorderColor #000000
  BackgroundColor #FFFFFF
  FontSize 12
  BorderThickness 1.5
}

rectangle "清单成员表\nlist_members" as E1

usecase "记录ID" as A1
usecase "清单ID" as A2
usecase "用户ID" as A3
usecase "角色" as A4
usecase "加入方式" as A5
usecase "邀请记录ID" as A6
usecase "加入时间" as A7

E1 -- A1
E1 -- A2
E1 -- A3
E1 -- A4
E1 -- A5
E1 -- A6
E1 -- A7

@enduml
