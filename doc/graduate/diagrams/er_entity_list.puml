@startuml 清单实体E-R图
' ============================================
' 图4.5 清单实体属性图
' 渲染：复制到 https://www.plantuml.com/plantuml/uml
' ============================================

skinparam defaultFontSize 13
skinparam defaultFontName Microsoft YaHei
skinparam backgroundColor white
skinparam shadowing false

skinparam rectangle {
  BorderColor #000000
  BackgroundColor #FFFFFF
  FontSize 14
  FontStyle bold
  BorderThickness 2
}

skinparam usecase {
  BorderColor #000000
  BackgroundColor #FFFFFF
  FontSize 12
  BorderThickness 1.5
}

rectangle "清单表\nlists" as E1

usecase "清单ID" as A1
usecase "名称" as A2
usecase "描述" as A3
usecase "是否共享" as A4
usecase "可见性" as A5
usecase "创建者ID" as A6
usecase "创建时间" as A7
usecase "更新时间" as A8

E1 -- A1
E1 -- A2
E1 -- A3
E1 -- A4
E1 -- A5
E1 -- A6
E1 -- A7
E1 -- A8

@enduml
