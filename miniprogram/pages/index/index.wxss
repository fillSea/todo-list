.container {
  padding: 0;
  min-height: 100vh;
  background: #f5f5f5;
}

.search-bar {
  background: white;
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 11;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 40rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 0 8rpx;
}

.search-result-header {
  padding: 16rpx 0;
}

.search-result-text {
  font-size: 26rpx;
  color: #999;
}

.category-tabs {
  display: flex;
  background: white;
  padding: 20rpx 0;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.category-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.category-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 30rpx;
  color: #666;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-tab.active {
  font-weight: 500;
}

.active-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  border-radius: 2rpx;
}

.task-sections {
  padding: 20rpx;
}

.task-section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.section-header.in-progress {
  background: #e6f7e6;
}

.section-header.in-progress .section-title {
  color: #07c160;
}

.section-header.overdue {
  background: #ffe6e6;
}

.section-header.overdue .section-title {
  color: #ee0a24;
}

.section-header.completed {
  background: #f5f5f5;
}

.section-header.completed .section-title {
  color: #999;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.section-count {
  font-size: 28rpx;
  color: #999;
  background: rgba(255, 255, 255, 0.8);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.empty-section {
  text-align: center;
  color: #999;
  padding: 60rpx 0;
  font-size: 28rpx;
}

.section-empty {
  text-align: center;
  padding: 30rpx 0;
}

.section-empty-text {
  font-size: 26rpx;
  color: #bbb;
}

.task-list {
  padding: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #1989fa;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.task-item.completed {
  opacity: 0.6;
}

.task-item.completed .task-title {
  text-decoration: line-through;
}

.task-content {
  flex: 1;
  margin-left: 20rpx;
}

.task-title {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.task-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-time {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.task-time.overdue {
  color: #ee0a24;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.guest-state {
  margin: 20rpx;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.guest-title {
  display: block;
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
}

.guest-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
}

.guest-button {
  margin-top: 32rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1989fa 0%, #07c160 100%);
  color: #fff;
  font-size: 30rpx;
  line-height: 88rpx;
}

.guest-button::after {
  border: none;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

.task-deadline {
  font-size: 26rpx;
  color: #999;
}

.task-deadline.overdue {
  color: #ee0a24;
}

.all-completed-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 40rpx;
  background: white;
  border-radius: 0 0 16rpx 16rpx;
}

.tip-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tip-icon {
  font-size: 40rpx;
  color: #07c160;
  font-weight: bold;
}

.tip-text {
  font-size: 30rpx;
  color: #999;
}

.task-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.stats-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  border-radius: 50%;
  margin-bottom: 4rpx;
}

.stats-icon {
  font-size: 28rpx;
}

.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #1989fa 0%, #07c160 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(25, 137, 250, 0.4);
  z-index: 100;
}

.fab-icon {
  color: white;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 300;
}
