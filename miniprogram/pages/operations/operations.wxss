/* 页面容器 */
.operations-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 操作记录列表 */
.operations-scroll {
  flex: 1;
  padding: 12px 16px;
}

.operation-list {
  background-color: #fff;
  border-radius: 12px;
  padding: 8px 16px;
}

.operation-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.operation-item:last-child {
  border-bottom: none;
}

.operation-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background-color: #909399;
}

.icon-task_create {
  background-color: #4CAF50;
}

.icon-task_create_repeat {
  background-color: #4CAF50;
}

.icon-task_update {
  background-color: #1976D2;
}

.icon-task_delete {
  background-color: #F44336;
}

.icon-task_delete_repeat {
  background-color: #F44336;
}

.icon-task_complete {
  background-color: #8BC34A;
}

.icon-list_create {
  background-color: #9C27B0;
}

.icon-list_update {
  background-color: #FF9800;
}

.icon-list_delete {
  background-color: #F44336;
}

.icon-invite_send {
  background-color: #1989FA;
}

.icon-invite_reject {
  background-color: #EE0A24;
}

.icon-invite_remind {
  background-color: #FF9800;
}

.icon-invite_cancel {
  background-color: #999;
}

.icon-invite_clear {
  background-color: #795548;
}

.icon-join_apply {
  background-color: #673AB7;
}

.icon-application_approve {
  background-color: #4CAF50;
}

.icon-application_reject {
  background-color: #F44336;
}

.icon-member_add {
  background-color: #00BCD4;
}

.icon-member_update {
  background-color: #607D8B;
}

.icon-member_remove {
  background-color: #795548;
}

.operation-content {
  flex: 1;
  min-width: 0;
}

.operation-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 8px;
  margin-bottom: 4px;
}

.operation-text {
  font-size: 15px;
  color: #333;
  flex: 1;
  line-height: 1.4;
}

.operation-time {
  font-size: 12px;
  color: #999;
  flex-shrink: 0;
}

.operation-user {
  font-size: 12px;
  color: #999;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px;
}

.load-text {
  font-size: 13px;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 16px;
  font-size: 13px;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 16px;
}

.empty-title {
  font-size: 16px;
  color: #666;
  margin-top: 16px;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 13px;
  color: #999;
}
