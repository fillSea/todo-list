<view class="notification-settings-container">
  <view class="tips-section" wx:if="{{!isLoggedIn}}">
    <view class="tip-item">
      <van-icon name="info-o" size="32rpx" color="#999" />
      <text class="tip-text">完善资料后可管理站内通知接收设置</text>
    </view>
  </view>

  <view class="settings-group" wx:if="{{isLoggedIn}}">
    <view class="setting-item">
      <view class="setting-icon">
        <van-icon name="bell" size="40rpx" color="#1989fa" />
      </view>
      <view class="setting-info">
        <text class="setting-title">接收通知</text>
        <text class="setting-desc">控制是否接收新的站内通知</text>
      </view>
      <switch class="setting-switch" checked="{{settings.enableNotifications}}" bindchange="onSettingChange" data-key="enableNotifications" color="#07C160" />
    </view>
  </view>

  <view class="tips-section" wx:if="{{isLoggedIn}}">
    <view class="tip-item">
      <van-icon name="info-o" size="32rpx" color="#999" />
      <text class="tip-text">关闭后将不再接收新的站内通知，但已收到的消息仍可在我的通知中查看</text>
    </view>
  </view>
</view>
