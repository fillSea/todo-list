<view class="notification-settings-container">
  <!-- 设置列表 -->
  <view class="settings-group">
    <view class="setting-item" wx:for="{{settingItems}}" wx:key="key">
      <view class="setting-icon" style="background: {{item.color}}20;">
        <van-icon name="{{item.icon}}" size="40rpx" color="{{item.color}}" />
      </view>
      <view class="setting-info">
        <text class="setting-title">{{item.title}}</text>
        <text class="setting-desc">{{item.desc}}</text>
      </view>
      <switch class="setting-switch" checked="{{settings[item.key]}}" bindchange="onSettingChange" data-key="{{item.key}}" color="#07C160" />
    </view>
  </view>

  <!-- 说明区域 -->
  <view class="tips-section">
    <view class="tip-item">
      <van-icon name="info-o" size="32rpx" color="#999" />
      <text class="tip-text">关闭"接收通知"后将不再接收任何推送通知，但您仍可在应用内查看消息</text>
    </view>
    <view class="tip-item">
      <van-icon name="info-o" size="32rpx" color="#999" />
      <text class="tip-text">如需接收微信订阅消息，请点击下方按钮开启权限</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="action-btn primary" bindtap="onRequestSubscribe">
      <van-icon name="bell" size="32rpx" color="#fff" />
      <text>开启订阅消息</text>
    </button>
    <button class="action-btn default" bindtap="onOpenSystemSettings">
      <van-icon name="setting-o" size="32rpx" color="#666" />
      <text>打开系统设置</text>
    </button>
  </view>
</view>
