.notifications-container {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 类型筛选 */
.type-filter {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-scroll {
  flex: 1;
  white-space: nowrap;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 28rpx;
  transition: all 0.2s;
}

.filter-item.active {
  background: #07C160;
  color: #fff;
}

.mark-all-btn {
  padding: 12rpx 20rpx;
  margin-left: 20rpx;
  font-size: 26rpx;
  color: #1989fa;
  white-space: nowrap;
}

/* 通知列表 */
.notifications-wrapper {
  padding: 20rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.1s;
}

.notification-item:active {
  transform: scale(0.98);
}

.notification-item.unread {
  background: #f0f9ff;
}

.notification-icon {
  width: 72rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.notification-item.unread .notification-icon {
  background: #e6f7ff;
}

.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.notification-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.notification-time {
  font-size: 24rpx;
  color: #999;
}

.notification-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notification-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #FF4D4F;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.delete-btn {
  padding: 10rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 30rpx;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #999;
}
