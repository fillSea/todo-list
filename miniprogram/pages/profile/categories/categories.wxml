<view class="categories-container">
  <!-- 分类列表 -->
  <view class="categories-wrapper">
    <view class="category-item" wx:for="{{categories}}" wx:key="_id">
      <view class="category-color" style="background: {{item.color}};"></view>
      <view class="category-info">
        <text class="category-name">{{item.name}}</text>
        <text class="category-count">{{item.taskCount || 0}}个任务</text>
      </view>
      <view class="category-actions">
        <view class="action-btn" bindtap="onShowEditModal" data-category="{{item}}">
          <van-icon name="edit" size="32rpx" color="#999" />
        </view>
        <view class="action-btn" bindtap="onDeleteCategory" data-category="{{item}}">
          <van-icon name="delete-o" size="32rpx" color="#999" />
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && categories.length === 0}}">
      <van-icon name="label-o" size="120rpx" color="#ddd" />
      <text class="empty-text">{{isLoggedIn ? '暂无分类标签' : '完善资料后查看分类标签'}}</text>
      <text class="empty-subtext">{{isLoggedIn ? '点击右下角按钮创建新分类' : '完善个人资料后可管理分类标签'}}</text>
    </view>
  </view>

  <!-- 创建按钮 -->
  <view class="fab-btn" bindtap="onShowCreateModal">
    <text class="fab-icon">+</text>
  </view>

  <!-- 编辑弹窗 -->
  <van-popup show="{{showEditModal}}" position="bottom" round bind:close="onCloseModal">
    <view class="edit-modal">
      <view class="modal-header">
        <text class="modal-title">{{editingCategory ? '编辑分类' : '新建分类'}}</text>
        <van-icon name="cross" size="40rpx" color="#999" bindtap="onCloseModal" />
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">分类名称</text>
          <input class="form-input" type="text" placeholder="请输入分类名称" value="{{formData.name}}" bindinput="onNameInput" maxlength="20" />
        </view>
        <view class="form-item">
          <text class="form-label">分类颜色</text>
          <view class="color-picker">
            <view class="color-item {{formData.color === item ? 'active' : ''}}" wx:for="{{presetColors}}" wx:key="*this" style="background: {{item}};" bindtap="onColorSelect" data-color="{{item}}">
              <van-icon wx:if="{{formData.color === item}}" name="success" size="32rpx" color="#fff" />
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="onCloseModal">取消</button>
        <button class="btn-confirm" bindtap="onSaveCategory">保存</button>
      </view>
    </view>
  </van-popup>
</view>
