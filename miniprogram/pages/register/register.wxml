<view class="register-container">
  <view class="header">
    <text class="title">用户注册</text>
  </view>
  
  <view class="form">
    <view class="form-item">
      <text class="label">用户名</text>
      <input class="input" placeholder="请输入用户名" bindinput="onUsernameInput" />
    </view>
    
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" bindinput="onPhoneInput" />
    </view>
    
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" password placeholder="请输入密码" bindinput="onPasswordInput" />
    </view>
    
    <button class="register-btn" bindtap="onRegister">注册</button>
  </view>
</view>
