/* 页面容器 */
.list-invite-manage-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 80px;
}

/* 顶部导航栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-left {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 40px;
  display: flex;
  justify-content: flex-end;
}

.clear-text {
  font-size: 14px;
  color: #ee0a24;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 14px;
  font-size: 14px;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1976D2;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 3rpx;
  background-color: #1976D2;
}

.tab-badge {
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  background-color: #ee0a24;
  color: #fff;
  font-size: 11px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 邀请列表滚动区域 */
.invite-scroll {
  flex: 1;
  padding: 12px 16px;
}

/* 邀请列表 */
.invite-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.invite-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  background-color: #fff;
  border-radius: 12px;
}

.invite-item.expired {
  opacity: 0.7;
}

.invite-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  flex-shrink: 0;
}

.invite-info {
  flex: 1;
  min-width: 0;
}

.invite-name {
  font-size: 15px;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 6px;
}

.invite-meta {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.invite-role {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 8px;
}

.invite-role.editor {
  background-color: #E8F5E9;
  color: #2E7D32;
}

.invite-role.viewer {
  background-color: #FFF3E0;
  color: #F57C00;
}

.invite-status {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 8px;
}

.invite-status.accepted {
  background-color: #E3F2FD;
  color: #1976D2;
}

.invite-status.expired {
  background-color: #F5F5F5;
  color: #999;
}

.invite-status.pending {
  background-color: #FFF3E0;
  color: #F57C00;
}

/* 申请项样式 */
.invite-item.application {
  align-items: flex-start;
}

.apply-message {
  font-size: 13px;
  color: #666;
  background-color: #f5f5f5;
  padding: 8px 12px;
  border-radius: 8px;
  margin-top: 8px;
  display: block;
}

.application-actions {
  flex-direction: row;
  gap: 8px;
}

.action-btn.reject {
  background-color: #FFEBEE;
  color: #ee0a24;
}

.action-btn.approve {
  background-color: #E8F5E9;
  color: #2E7D32;
}

.invite-time {
  font-size: 12px;
  color: #999;
}

.invite-type {
  font-size: 12px;
  color: #999;
}

.invite-actions {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.action-btn {
  padding: 6px 12px;
  font-size: 12px;
  border-radius: 12px;
  text-align: center;
}

.action-btn.remind {
  background-color: #E3F2FD;
  color: #1976D2;
}

.action-btn.cancel {
  background-color: #FFEBEE;
  color: #ee0a24;
}

.action-btn.reinvite {
  background-color: #E8F5E9;
  color: #2E7D32;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 16px;
}

.empty-title {
  font-size: 16px;
  color: #666;
  margin-top: 16px;
  margin-bottom: 8px;
}

.empty-desc {
  font-size: 13px;
  color: #999;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px;
}

.load-text {
  font-size: 13px;
  color: #999;
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #eee;
}

.invite-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px;
  background-color: #1976D2;
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  border-radius: 24px;
}

.invite-btn:active {
  background-color: #1565C0;
}