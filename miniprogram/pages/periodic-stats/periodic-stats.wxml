<view class="container">
  <van-nav-bar title="周期任务统计" left-text="返回" left-arrow bind:click-left="onBack" />

  <view wx:if="{{loading}}" class="loading-container">
    <van-loading type="spinner" size="40px">加载中...</van-loading>
  </view>

  <view wx:elif="{{error}}" class="error-container">
    <van-empty description="{{error}}" />
  </view>

  <view wx:else class="content">
    <!-- 任务信息 -->
    <view class="task-info-card">
      <view class="task-title">{{taskInfo.title}}</view>
      <view class="task-meta">
        <van-tag type="primary" wx:if="{{taskInfo.repeatType === 1}}">每天</van-tag>
        <van-tag type="primary" wx:if="{{taskInfo.repeatType === 2}}">每周</van-tag>
        <van-tag type="primary" wx:if="{{taskInfo.repeatType === 3}}">每月</van-tag>
        <van-tag color="{{priorityColor}}" style="margin-left: 10rpx;">{{priorityText}}</van-tag>
      </view>
    </view>

    <!-- 统计概览 -->
    <view class="stats-overview-card">
      <view class="card-title">完成概览</view>
      <view class="stats-grid">
        <view class="stats-item">
          <view class="stats-value highlight">{{stats.completionRate}}%</view>
          <view class="stats-label">完成率</view>
        </view>
        <view class="stats-item">
          <view class="stats-value green">{{stats.completedCount}}</view>
          <view class="stats-label">已完成</view>
        </view>
        <view class="stats-item">
          <view class="stats-value red">{{stats.incompleteCount}}</view>
          <view class="stats-label">未完成</view>
        </view>
        <view class="stats-item">
          <view class="stats-value">{{stats.totalCount}}</view>
          <view class="stats-label">已到期</view>
        </view>
      </view>
      <view class="progress-section">
        <van-progress percentage="{{stats.completionRate}}" stroke-height="16" color="#07c160" />
      </view>
    </view>

    <!-- 连续完成 -->
    <view class="streak-card">
      <view class="streak-title">连续完成</view>
      <view class="streak-content">
        <view class="streak-item">
          <view class="streak-icon">🔥</view>
          <view class="streak-info">
            <view class="streak-value">{{stats.currentStreak}}</view>
            <view class="streak-label">当前连续</view>
          </view>
        </view>
        <view class="streak-divider"></view>
        <view class="streak-item">
          <view class="streak-icon">🏆</view>
          <view class="streak-info">
            <view class="streak-value">{{stats.longestStreak}}</view>
            <view class="streak-label">最长连续</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 按月日历 -->
    <view class="calendar-card" wx:for="{{calendarMonths}}" wx:key="label">
      <view class="card-title">{{item.label}}</view>
      <view class="weekday-header">
        <view class="weekday">日</view>
        <view class="weekday">一</view>
        <view class="weekday">二</view>
        <view class="weekday">三</view>
        <view class="weekday">四</view>
        <view class="weekday">五</view>
        <view class="weekday">六</view>
      </view>
      <view class="calendar-grid">
        <view wx:for="{{item.days}}" wx:for-item="day" wx:key="date"
          class="calendar-day {{day.status === 1 ? 'completed' : day.status === 0 ? 'incomplete' : day.status === 2 ? 'future' : ''}}">
          <view class="day-number">{{day.day}}</view>
          <view wx:if="{{day.status === 1}}" class="status-dot completed-dot"></view>
          <view wx:elif="{{day.status === 0}}" class="status-dot incomplete-dot"></view>
          <view wx:elif="{{day.status === 2}}" class="status-dot future-dot"></view>
        </view>
      </view>
    </view>

    <!-- 图例 -->
    <view class="legend">
      <view class="legend-item">
        <view class="legend-dot completed-bg"></view>
        <text>已完成</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot incomplete-bg"></view>
        <text>未完成</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot future-bg"></view>
        <text>待完成</text>
      </view>
    </view>

    <!-- 历史记录 -->
    <view class="history-card" wx:if="{{historyRecords.length > 0}}">
      <view class="card-title">历史记录</view>
      <view class="history-list">
        <view wx:for="{{historyRecords}}" wx:key="date" class="history-item">
          <view class="history-date">{{item.formattedDate}}</view>
          <view class="history-status {{item.status === 1 ? 'status-completed' : 'status-incomplete'}}">
            {{item.status === 1 ? '已完成' : '未完成'}}
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
