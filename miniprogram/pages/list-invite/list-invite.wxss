/* 页面容器 */
.list-invite-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 顶部导航栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-left {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-title {
  font-size: 17px;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 40px;
}

/* 清单信息 */
.list-info {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  background-color: #fff;
  margin-bottom: 12px;
}

.list-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid;
}

.list-meta {
  flex: 1;
}

.list-name {
  font-size: 16px;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4px;
}

.list-desc {
  font-size: 13px;
  color: #999;
}

/* 邀请方式选择 */
.invite-methods {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.section-title {
  font-size: 14px;
  color: #666;
  margin-bottom: 16px;
}

.methods-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

.method-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 8px;
  background-color: #f5f5f5;
  border-radius: 12px;
  transition: all 0.3s;
}

.method-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.share-panel {
  margin: 0 16px 12px;
  padding: 16px;
  background: linear-gradient(135deg, #e8f8ef 0%, #ffffff 100%);
  border-radius: 16px;
  border: 1rpx solid #ccebd8;
}

.share-panel.link-mode {
  background: linear-gradient(135deg, #eef5ff 0%, #ffffff 100%);
  border-color: #d7e6ff;
}

.share-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}

.share-header-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.share-title {
  font-size: 16px;
  color: #1f6f43;
  font-weight: 600;
}

.share-panel.link-mode .share-title {
  color: #1a4f9c;
}

.share-role {
  font-size: 12px;
  color: #07c160;
  background-color: #e7f9ef;
  padding: 4px 10px;
  border-radius: 999px;
}

.share-panel.link-mode .share-role {
  color: #1976D2;
  background-color: #e8f1ff;
}

.share-status {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 6px;
}

.share-help {
  display: block;
  font-size: 12px;
  line-height: 1.6;
  color: #666;
  margin-bottom: 14px;
}

.share-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 14px;
}

.share-tag {
  padding: 4px 10px;
  background-color: #f3f6fb;
  color: #4a5a70;
  border-radius: 999px;
  font-size: 12px;
}

.share-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  border-radius: 22px;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

.share-btn.primary {
  background-color: #07c160;
}

.share-panel.link-mode .share-btn.primary {
  background-color: #1976D2;
}

.share-btn.secondary {
  margin-top: 10px;
  background-color: #fff;
  color: #1976D2;
  border: 1rpx solid #c6dafb;
}

.share-btn::after {
  border: none;
}

.share-btn:active {
  opacity: 0.9;
}

.share-regenerate {
  margin-top: 12px;
  text-align: center;
  color: #1976D2;
  font-size: 13px;
}

.link-settings-inline {
  margin-top: 16px;
  border-top: 1rpx solid #e8edf5;
  padding-top: 12px;
}

.settings-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}

.settings-toggle-text {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.settings-toggle-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.settings-summary {
  font-size: 12px;
  color: #999;
}

.settings-body {
  margin-top: 12px;
  background-color: rgba(255, 255, 255, 0.72);
  border-radius: 12px;
  padding: 0 12px;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
  min-width: 0;
}

.setting-name {
  font-size: 15px;
  color: #333;
  display: block;
  margin-bottom: 4px;
}

.setting-desc {
  font-size: 12px;
  color: #999;
  line-height: 1.5;
}

.setting-value {
  display: flex;
  align-items: center;
  gap: 4px;
  color: #666;
  font-size: 14px;
  flex-shrink: 0;
}

.setting-item.inline {
  padding: 14px 0;
}

.setting-item.inline.no-border {
  border-bottom: none;
}

.method-icon {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.method-icon.wechat {
  background-color: #07C160;
}

.method-icon.link {
  background-color: #1976D2;
}

.method-icon.search {
  background-color: #FF9800;
}

.method-icon.recent {
  background-color: #9C27B0;
}

.method-name {
  font-size: 13px;
  color: #333;
  font-weight: 500;
  margin-bottom: 2px;
}

.method-desc {
  font-size: 11px;
  color: #999;
}

/* 待处理邀请 */
.pending-section {
  background-color: #fff;
  padding: 16px;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.view-all {
  font-size: 13px;
  color: #1976D2;
}

.pending-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.pending-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 12px;
}

.pending-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  flex-shrink: 0;
}

.pending-info {
  flex: 1;
  min-width: 0;
}

.pending-name {
  font-size: 15px;
  color: #333;
  display: block;
  margin-bottom: 4px;
}

.pending-role {
  font-size: 12px;
  color: #999;
}

.pending-status {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 10px;
  flex-shrink: 0;
}

.pending-status.waiting {
  background-color: #E3F2FD;
  color: #1976D2;
}

.pending-status.expired {
  background-color: #F5F5F5;
  color: #999;
}

/* 最近协作成员 */
.recent-section {
  background-color: #fff;
  padding: 16px;
  flex: 1;
}

.recent-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.recent-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 12px;
  width: calc(25% - 12px);
  min-width: 70px;
  position: relative;
}

.recent-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
}

.recent-name {
  font-size: 12px;
  color: #666;
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-btn {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 20px;
  height: 20px;
  background-color: #E3F2FD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗样式 */
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1rpx solid #eee;
}

.popup-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.popup-content {
  padding: 16px;
  max-height: 60vh;
  overflow-y: auto;
}

.expire-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.expire-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  background-color: #f5f5f5;
  border-radius: 12px;
  border: 2px solid transparent;
}

.expire-option.active {
  background-color: #E3F2FD;
  border-color: #1976D2;
}

.expire-name {
  font-size: 15px;
  color: #333;
}

/* 权限选项 */
.role-options {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 24px;
}

.role-option {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  background-color: #f5f5f5;
  border-radius: 12px;
  border: 2px solid transparent;
  transition: all 0.3s;
}

.role-option.active {
  background-color: #E3F2FD;
  border-color: #1976D2;
}

.role-icon {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.role-icon.editor {
  background-color: #4CAF50;
}

.role-icon.viewer {
  background-color: #FF9800;
}

.role-info {
  flex: 1;
  min-width: 0;
}

.role-name {
  font-size: 15px;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 4px;
}

.role-desc {
  font-size: 12px;
  color: #999;
  line-height: 1.4;
}

.role-radio {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid #ddd;
  background-color: #fff;
  flex-shrink: 0;
  transition: all 0.3s;
}

.role-radio.active {
  background-color: #1976D2;
  border-color: #1976D2;
}

.submit-btn {
  padding: 14px;
  background-color: #1976D2;
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  text-align: center;
  border-radius: 24px;
}

.submit-btn:active {
  background-color: #1565C0;
}

/* 搜索弹窗 */
.search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  background-color: #f5f5f5;
  border-radius: 24px;
  margin-bottom: 16px;
}

.search-input {
  flex: 1;
  font-size: 15px;
  color: #333;
}

.search-clear {
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-result {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.result-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background-color: #f5f5f5;
  border-radius: 12px;
}

.result-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
  min-width: 0;
}

.result-name {
  font-size: 15px;
  color: #333;
  display: block;
  margin-bottom: 4px;
}

.result-id {
  font-size: 12px;
  color: #999;
}

.result-btn {
  padding: 8px 16px;
  background-color: #1976D2;
  color: #fff;
  font-size: 14px;
  border-radius: 16px;
}

.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 16px;
  color: #999;
}

.search-empty text {
  margin-top: 12px;
  font-size: 14px;
}
