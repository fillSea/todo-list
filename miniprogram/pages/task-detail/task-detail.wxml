<view class="container">
  <!-- 任务名称 -->
  <view class="form-item">
    <view class="form-label">
      <van-checkbox value="{{task.status === 1}}" bind:change="onStatusChange" shape="round" />
      <text class="label-text">任务名称</text>
    </view>
    <input class="form-input" value="{{task.title}}" bindinput="onTitleChange" placeholder="请输入任务名称" />
  </view>

  <!-- 任务优先级 -->
  <view class="form-item">
    <text class="form-label-text">任务优先级</text>
    <picker bindchange="onPriorityChange" value="{{priorityIndex}}" range="{{priorityOptions}}" range-key="label">
      <view class="picker-value">
        <text>{{priorityOptions[priorityIndex].label}}</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>

  <!-- 任务分类 -->
  <view class="form-item">
    <text class="form-label-text">任务分类</text>
    <picker bindchange="onCategoryChange" value="{{categoryIndex}}" range="{{categoryOptions}}" range-key="name">
      <view class="picker-value">
        <text>{{categoryOptions[categoryIndex].name}}</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>

  <!-- 任务截止时间 -->
  <view class="form-item">
    <text class="form-label-text">任务截止时间</text>
    <picker mode="multiSelector" bindchange="onDueDateChange" bindcolumnchange="onDueDateColumnChange" value="{{dueDateIndex}}" range="{{dueDateRange}}">
      <view class="picker-value">
        <text>{{formattedDueDate}}</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>

  <!-- 任务周期 -->
  <view class="form-item">
    <text class="form-label-text">任务周期</text>
    <switch checked="{{task.repeatType > 0}}" bindchange="onRepeatToggle" />
  </view>

  <!-- 周期类型选择 -->
  <view class="form-item" wx:if="{{task.repeatType > 0}}">
    <text class="form-label-text">周期类型</text>
    <picker bindchange="onRepeatTypeChange" value="{{repeatTypeIndex}}" range="{{repeatTypeOptions}}" range-key="label">
      <view class="picker-value">
        <text>{{repeatTypeOptions[repeatTypeIndex].label}}</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>

  <!-- 每周重复选择 -->
  <view class="form-item" wx:if="{{task.repeatType === 1}}">
    <text class="form-label-text">重复日期</text>
    <view class="weekday-selector">
      <view wx:for="{{weekDays}}" wx:key="*this" class="weekday-item {{selectedWeekDays[index] ? 'selected' : ''}}" bindtap="onWeekDayToggle" data-index="{{index}}">
        {{item}}
      </view>
    </view>
  </view>

  <!-- 每月重复选择 -->
  <view class="form-item" wx:if="{{task.repeatType === 2}}">
    <text class="form-label-text">重复日期</text>
    <picker bindchange="onMonthDayChange" value="{{monthDayIndex}}" range="{{monthDays}}">
      <view class="picker-value">
        <text>每月{{task.repeatValue || 1}}日</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>

  <!-- 任务描述 -->
  <view class="form-item form-item-textarea">
    <text class="form-label-text">任务描述</text>
    <textarea class="form-textarea" value="{{task.description}}" bindinput="onDescriptionChange" placeholder="请输入任务描述" maxlength="500" />
  </view>

  <!-- 设置提醒 -->
  <view class="form-item">
    <text class="form-label-text">设置提醒</text>
    <switch checked="{{enableReminder}}" bindchange="onReminderToggle" />
  </view>

  <!-- 提醒时间 -->
  <view class="form-item" wx:if="{{enableReminder}}">
    <text class="form-label-text">提醒时间</text>
    <picker mode="multiSelector" bindchange="onReminderTimeChange" value="{{reminderIndex}}" range="{{reminderRange}}">
      <view class="picker-value">
        <text>{{formattedReminderTime}}</text>
        <text class="arrow">></text>
      </view>
    </picker>
  </view>

  <!-- 底部按钮 -->
  <view class="button-group">
    <button class="btn btn-cancel" bindtap="onCancel">取消</button>
    <button class="btn btn-delete" bindtap="onDelete">删除任务</button>
    <button class="btn btn-save" bindtap="onSave">保存任务</button>
  </view>
</view>

<!-- 删除确认弹窗 -->
<van-dialog id="van-dialog" />
