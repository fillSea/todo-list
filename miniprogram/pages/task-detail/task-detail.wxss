.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.form-label-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.label-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #333;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  color: #666;
}

.arrow {
  color: #999;
  font-size: 28rpx;
}

.form-item-textarea {
  flex-direction: column;
  align-items: flex-start;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
}

/* 星期选择器 */
.weekday-selector {
  display: flex;
  gap: 16rpx;
}

.weekday-item {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f5f5;
  font-size: 28rpx;
  color: #666;
}

.weekday-item.selected {
  background: #1989fa;
  color: white;
}

/* 底部按钮 */
.button-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-delete {
  background: #ff4d4f;
  color: white;
}

.btn-save {
  background: #1989fa;
  color: white;
}

.btn::after {
  border: none;
}
