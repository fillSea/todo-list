<view class="list-edit-container">
    <!-- 顶部导航栏 -->
    <view class="header">
        <view class="header-left" bindtap="onCancel">
            <van-icon name="cross" size="20px" color="#333" />
        </view>
        <text class="header-title">{{isEditing ? '编辑清单' : '创建清单'}}</text>
        <view class="header-right">
            <text class="save-btn" bindtap="onSave">保存</text>
        </view>
    </view>
    <!-- 表单内容 -->
    <scroll-view class="form-scroll" scroll-y>
        <!-- 清单名称 -->
        <view class="form-section">
            <view class="form-item">
                <text class="form-label required">清单名称</text>
                <input class="form-input" placeholder="请输入清单名称" value="{{formData.name}}" bindinput="onNameInput" maxlength="50" />
            </view>
        </view>
        <!-- 清单描述 -->
        <view class="form-section">
            <view class="form-item">
                <text class="form-label">清单描述</text>
                <textarea class="form-textarea" placeholder="请输入清单描述（可选）" value="{{formData.description}}" bindinput="onDescInput" maxlength="200" auto-height />
            </view>
        </view>
        <!-- 清单类型 -->
        <view class="form-section">
            <view class="form-item">
                <text class="form-label required">清单类型</text>
                <view class="type-options">
                    <view class="type-option {{formData.isShared ? '' : 'active'}}" data-type="personal" bindtap="onTypeChange">
                        <view class="type-icon personal">
                            <van-icon name="label-o" size="24px" color="#1976D2" />
                        </view>
                        <view class="type-info">
                            <text class="type-name">个人清单</text>
                            <text class="type-desc">仅自己可见和管理</text>
                        </view>
                        <van-icon name="success" size="20px" color="#1976D2" wx:if="{{!formData.isShared}}" />
                    </view>
                    <view class="type-option {{formData.isShared ? 'active' : ''}}" data-type="shared" bindtap="onTypeChange">
                        <view class="type-icon shared">
                            <van-icon name="friends-o" size="24px" color="#2E7D32" />
                        </view>
                        <view class="type-info">
                            <text class="type-name">共享清单</text>
                            <text class="type-desc">可邀请他人协作</text>
                        </view>
                        <van-icon name="success" size="20px" color="#1976D2" wx:if="{{formData.isShared}}" />
                    </view>
                </view>
            </view>
        </view>
        <!-- 可见性设置（仅共享清单显示） -->
        <view class="form-section" wx:if="{{formData.isShared}}">
            <view class="form-item">
                <text class="form-label required">可见性</text>
                <view class="visibility-options">
                    <view class="visibility-option {{formData.visibility === 1 ? 'active' : ''}}" data-visibility="1" bindtap="onVisibilityChange">
                        <view class="visibility-icon">
                            <van-icon name="eye-o" size="20px" color="#F57C00" />
                        </view>
                        <view class="visibility-info">
                            <text class="visibility-name">公开</text>
                            <text class="visibility-desc">所有成员可见</text>
                        </view>
                        <view class="visibility-radio {{formData.visibility === 1 ? 'active' : ''}}"></view>
                    </view>
                    <view class="visibility-option {{formData.visibility === 2 ? 'active' : ''}}" data-visibility="2" bindtap="onVisibilityChange">
                        <view class="visibility-icon">
                            <van-icon name="closed-eye" size="20px" color="#666" />
                        </view>
                        <view class="visibility-info">
                            <text class="visibility-name">私密</text>
                            <text class="visibility-desc">仅成员可见</text>
                        </view>
                        <view class="visibility-radio {{formData.visibility === 2 ? 'active' : ''}}"></view>
                    </view>
                </view>
            </view>
        </view>
        <!-- 清单颜色 -->
        <view class="form-section">
            <view class="form-item">
                <text class="form-label">清单颜色</text>
                <view class="color-options">
                    <view class="color-option {{formData.color === item ? 'active' : ''}}" wx:for="{{colorOptions}}" wx:key="*this" style="background-color: {{item}}" data-color="{{item}}" bindtap="onColorChange">
                        <van-icon name="success" size="16px" color="#fff" wx:if="{{formData.color === item}}" />
                    </view>
                </view>
            </view>
        </view>
    </scroll-view>
    <!-- 删除按钮（编辑模式） -->
    <view class="delete-section" wx:if="{{isEditing}}">
        <view class="delete-btn" bindtap="onDelete">
            <van-icon name="delete-o" size="18px" color="#ee0a24" />
            <text>删除清单</text>
        </view>
    </view>
    <!-- 删除确认弹窗 -->
    <van-dialog id="delete-dialog" show="{{showDeleteDialog}}" title="确认删除" message="删除后无法恢复，确定要删除此清单吗？清单中的所有任务也会被删除。" show-cancel-button confirm-button-text="删除" confirm-button-color="#ee0a24" bind:close="onDeleteDialogClose" bind:confirm="onDeleteConfirm" />
</view>